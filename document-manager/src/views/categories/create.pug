extends ../layouts/main

block content
  div(class="mb-6")
    h2.page-title Nueva categoria
    p(class="mt-1 text-sm text-slate-500") Define un grupo para clasificar documentos.

  section(class="panel max-w-2xl p-6")
    form(action="/categories" method="POST" class="space-y-5" novalidate)
      input(type="hidden" name="_csrf" value=csrfToken)
      div
        label.form-label(for="name") Nombre
        input#name.form-input(type="text" name="name" required maxlength="120" value=formData.name || "")
      div
        label.form-label(for="description") Descripcion
        textarea#description.form-input(name="description" rows="4" maxlength="500")= formData.description || ""
      div(class="flex flex-col-reverse gap-3 pt-2 sm:flex-row sm:justify-end")
        a.btn-secondary(href="/categories") Cancelar
        button.btn-primary(type="submit") Guardar categoria
