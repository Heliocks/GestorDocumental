extends ../layouts/main

block content
  div(class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between")
    div
      h2.page-title Aprobar
      p(class="mt-1 text-sm text-slate-500")= isAdminApproval ? "Documentos en Revision pendientes de aprobacion." : "Documentos en Revision donde eres el dueno asignado."

  section(class="panel overflow-hidden")
    if documents.length
      div(class="overflow-x-auto")
        table(class="min-w-full divide-y divide-slate-100")
          thead.table-header
            tr
              th(class="px-4 py-3") Documento
              th(class="px-4 py-3") Categoria
              th(class="px-4 py-3") Departamento
              th(class="px-4 py-3") Empresa
              if isAdminApproval
                th(class="px-4 py-3") Dueno
              th(class="px-4 py-3") Alta
              th(class="px-4 py-3") Tamano
              th(class="px-4 py-3 text-right") Acciones
          tbody(class="divide-y divide-slate-100 bg-white")
            each document in documents
              tr(class="hover:bg-slate-50")
                td.table-cell
                  p(class="font-semibold text-slate-900")= document.title
                  p(class="mt-1 text-xs text-slate-500")= document.original_filename
                td.table-cell= document.category_name || "Sin categoria"
                td.table-cell= document.department_name || "Sin departamento"
                td.table-cell= document.company_name || "Sin empresa"
                if isAdminApproval
                  td.table-cell
                    p(class="font-medium text-slate-900")= document.owner_user_name || "Sin dueno"
                    if document.owner_user_email
                      p(class="mt-1 text-xs text-slate-500")= document.owner_user_email
                td.table-cell= formatDateOnly(document.document_date)
                td.table-cell= formatBytes(Number(document.file_size))
                td.table-cell
                  div(class="flex flex-wrap justify-end gap-2")
                    form(action="/approvals/" + document.id + "/approve?_method=PATCH" method="POST")
                      input(type="hidden" name="_csrf" value=csrfToken)
                      button(type="submit" class="btn-primary px-3 py-1.5") Aprobar
                    form(action="/approvals/" + document.id + "/reject?_method=PATCH" method="POST")
                      input(type="hidden" name="_csrf" value=csrfToken)
                      button(type="submit" class="btn-danger px-3 py-1.5") Rechazar
                    a(class="btn-secondary px-3 py-1.5" href="/documents/" + document.id + "/download") Descargar
                    a(class="btn-secondary px-3 py-1.5" href="/documents/" + document.id) Ver
    else
      div(class="px-5 py-12 text-center")
        h3(class="text-base font-semibold text-slate-900") No hay documentos por aprobar
        p(class="mt-1 text-sm text-slate-500")= isAdminApproval ? "No hay documentos con estado Revision." : "Cuando un documento en Revision tenga tu usuario como dueno, aparecera aqui."
