extends ../layouts/main

block content
  div(class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between")
    div
      h2.page-title= document.title
      p(class="mt-1 text-sm text-slate-500") Detalle y metadata del documento.
    div(class="flex gap-2")
      a.btn-secondary(href="/documents") Volver
      if currentUser && currentUser.role === "admin"
        a.btn-secondary(href="/documents/" + document.id + "/edit") Editar
      a.btn-primary(href="/documents/" + document.id + "/download") Descargar

  section(class="grid gap-6 xl:grid-cols-[1fr_320px]")
    article(class="panel p-6")
      h3(class="text-base font-semibold text-slate-900") Informacion general
      dl(class="mt-5 grid gap-5 sm:grid-cols-2")
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Titulo
          dd(class="mt-1 text-sm text-slate-900")= document.title
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Categoria
          dd(class="mt-1 text-sm text-slate-900")= document.category_name || "Sin categoria"
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Departamento
          dd(class="mt-1 text-sm text-slate-900")= document.department_name || "Sin departamento"
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Empresa
          dd(class="mt-1 text-sm text-slate-900")= document.company_name || "Sin empresa"
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Dueño
          dd(class="mt-1 text-sm text-slate-900")
            if document.owner_user_name
              span= document.owner_user_name
              if document.owner_user_email
                span(class="block text-xs text-slate-500")= document.owner_user_email
            else
              span Sin dueño
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Estado
          dd(class="mt-1")
            span(class="badge bg-light_cyan-800 text-deep_twilight-500")= document.document_status || "Creación"
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Mostrar
          dd(class="mt-1 text-sm text-slate-900")
            if document.visible_users && document.visible_users.length
              ul(class="space-y-1")
                each visibleUser in document.visible_users
                  li
                    span= visibleUser.name
                    if visibleUser.email
                      span(class="block text-xs text-slate-500")= visibleUser.email
            else
              span Sin usuarios asignados
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Archivo original
          dd(class="mt-1 break-all text-sm text-slate-900")= document.original_filename
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Tipo
          dd(class="mt-1 text-sm text-slate-900")= document.file_type
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Tamano
          dd(class="mt-1 text-sm text-slate-900")= formatBytes(Number(document.file_size))
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Cargado por
          dd(class="mt-1 text-sm text-slate-900")= document.uploaded_by_name || "Sin usuario"
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Fecha de alta
          dd(class="mt-1 text-sm text-slate-900")= formatDateOnly(document.document_date)
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Fecha de carga
          dd(class="mt-1 text-sm text-slate-900")= formatDate(document.created_at)
        div
          dt(class="text-xs font-semibold uppercase tracking-wide text-slate-500") Ultima actualizacion
          dd(class="mt-1 text-sm text-slate-900")= formatDate(document.updated_at)
      if document.description
        div(class="mt-6 border-t border-slate-100 pt-5")
          h4(class="text-sm font-semibold text-slate-900") Descripcion
          p(class="mt-2 whitespace-pre-line text-sm leading-6 text-slate-600")= document.description

    aside(class="panel p-6")
      h3(class="text-base font-semibold text-slate-900") Acciones
      div(class="mt-5 space-y-3")
        a.btn-primary(class="w-full" href="/documents/" + document.id + "/download") Descargar archivo
        if currentUser && currentUser.role === "admin"
          a.btn-secondary(class="w-full" href="/documents/" + document.id + "/edit") Editar documento
          form(action="/documents/" + document.id + "?_method=DELETE" method="POST" data-confirm="Eliminar este documento logicamente?")
            input(type="hidden" name="_csrf" value=csrfToken)
            button.btn-danger(type="submit" class="w-full") Eliminar logicamente
