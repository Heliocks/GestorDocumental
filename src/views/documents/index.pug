extends ../layouts/main

block content
  div(class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between")
    div
      h2.page-title Documentos
      p(class="mt-1 text-sm text-slate-500") Consulta, filtra y administra documentos digitales.
    if currentUser && currentUser.role === "admin"
      a.btn-primary(href="/documents/create") Cargar documento

  form(action="/documents" method="GET" class="panel mb-6 grid gap-4 p-4 xl:grid-cols-[1fr_180px_180px_180px_200px_180px_auto]")
    div
      label.form-label(for="search") Buscar por titulo
      input#search.form-input(type="search" name="search" value=filters.search placeholder="Ej. contrato marco")
    div
      label.form-label(for="category_id") Categoria
      select#category_id.form-input(name="category_id")
        option(value="" selected=!filters.categoryId) Todas
        each category in categories
          option(value=category.id selected=String(category.id) === String(filters.categoryId))= category.name
    div
      label.form-label(for="department_id") Departamento
      select#department_id.form-input(name="department_id")
        option(value="" selected=!filters.departmentId) Todos
        each department in departments
          option(value=department.id selected=String(department.id) === String(filters.departmentId))= department.name
    div
      label.form-label(for="company_id") Empresa
      select#company_id.form-input(name="company_id")
        option(value="" selected=!filters.companyId) Todas
        each company in companies
          option(value=company.id selected=String(company.id) === String(filters.companyId))= company.name
    div
      label.form-label(for="owner_user_id") Dueño
      select#owner_user_id.form-input(name="owner_user_id")
        option(value="" selected=!filters.ownerUserId) Todos
        each owner in ownerUsers
          option(value=owner.id selected=String(owner.id) === String(filters.ownerUserId))= owner.name
    if currentUser && currentUser.role === "admin"
      div
        label.form-label(for="document_status") Estado
        select#document_status.form-input(name="document_status")
          option(value="" selected=!filters.documentStatus) Todos
          each status in documentStatuses
            option(value=status selected=status === filters.documentStatus)= status
    else
      input(type="hidden" name="document_status" value="Vigente")
    div(class="flex items-end gap-2")
      button.btn-primary(type="submit") Filtrar
      a.btn-secondary(href="/documents") Limpiar

  section(class="panel overflow-hidden")
    if documents.length
      div(class="overflow-x-auto")
        table(class="min-w-full divide-y divide-slate-100")
          thead.table-header
            tr
              th(class="px-4 py-3") Documento
              th(class="px-4 py-3") Categoria
              th(class="px-4 py-3") Departamento
              th(class="px-4 py-3") Empresa
              th(class="px-4 py-3") Dueño
              th(class="px-4 py-3") Mostrar
              th(class="px-4 py-3") Estado
              th(class="px-4 py-3") Tipo
              th(class="px-4 py-3") Tamano
              th(class="px-4 py-3") Alta
              th(class="px-4 py-3 text-right") Acciones
          tbody(class="divide-y divide-slate-100 bg-white")
            each document in documents
              tr(class="hover:bg-slate-50")
                td.table-cell
                  p(class="font-semibold text-slate-900")= document.title
                  p(class="mt-1 text-xs text-slate-500")= document.original_filename
                td.table-cell= document.category_name || "Sin categoria"
                td.table-cell= document.department_name || "Sin departamento"
                td.table-cell= document.company_name || "Sin empresa"
                td.table-cell
                  p(class="font-medium text-slate-900")= document.owner_user_name || "Sin dueño"
                  if document.owner_user_email
                    p(class="mt-1 text-xs text-slate-500")= document.owner_user_email
                td.table-cell #{document.visible_users_count || 0} usuario(s)
                td.table-cell
                  span(class="badge bg-light_cyan-800 text-deep_twilight-500")= document.document_status || "Creación"
                td.table-cell= document.file_type
                td.table-cell= formatBytes(Number(document.file_size))
                td.table-cell= formatDateOnly(document.document_date)
                td.table-cell
                  div(class="flex justify-end gap-2")
                    a(class="btn-secondary px-3 py-1.5" href="/documents/" + document.id) Ver
                    a(class="btn-secondary px-3 py-1.5" href="/documents/" + document.id + "/download") Descargar
                    if currentUser && currentUser.role === "admin"
                      a(class="btn-primary px-3 py-1.5" href="/documents/" + document.id + "/edit") Editar
    else
      div(class="px-5 py-12 text-center")
        h3(class="text-base font-semibold text-slate-900") No se encontraron documentos
        p(class="mt-1 text-sm text-slate-500") Ajusta los filtros para revisar los documentos disponibles.
        if currentUser && currentUser.role === "admin"
          a.btn-primary(class="mt-5" href="/documents/create") Cargar documento
