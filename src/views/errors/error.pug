extends ../layouts/main

block content
  section(class="mx-auto max-w-2xl rounded-lg border border-slate-200 bg-white p-8 text-center shadow-sm")
    p(class="text-sm font-semibold uppercase tracking-wide text-bright_teal_blue-500") Error #{status}
    h2(class="mt-3 text-2xl font-semibold text-deep_twilight-500")= title
    p(class="mt-3 text-sm leading-6 text-slate-600")= message
    div(class="mt-6")
      if currentUser
        a.btn-primary(href="/dashboard") Volver al dashboard
      else
        a.btn-primary(href="/login") Iniciar sesion
