if flash && flash.success
  div(class="mb-4 space-y-2")
    each message in flash.success
      div(class="rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800")= message

if flash && flash.error
  div(class="mb-4 space-y-2")
    each message in flash.error
      div(class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-800")= message

if errors && errors.length
  div(class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3")
    p(class="text-sm font-semibold text-red-800") Revisa la informacion capturada.
    ul(class="mt-2 list-disc space-y-1 pl-5 text-sm text-red-700")
      each error in errors
        li= error
