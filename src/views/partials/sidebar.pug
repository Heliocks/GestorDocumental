mixin navLink(href, label, marker, exact)
  - const isActive = exact ? currentPath === href : currentPath === href || currentPath.startsWith(href + '/')
  a(href=href class=isActive ? "flex items-center gap-3 rounded-md bg-white/10 px-3 py-2 text-sm font-semibold text-white" : "flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium text-frosted_blue-800 transition hover:bg-white/10 hover:text-white")
    span(class=isActive ? "flex h-8 w-8 items-center justify-center rounded-md bg-turquoise_surf-500 text-xs font-bold text-deep_twilight-500" : "flex h-8 w-8 items-center justify-center rounded-md bg-white/10 text-xs font-bold text-frosted_blue-800")= marker
    span= label

aside#sidebar(class="fixed inset-y-0 left-0 z-40 flex w-72 -translate-x-full flex-col bg-deep_twilight-500 px-4 py-5 shadow-xl transition-transform duration-200 lg:translate-x-0")
  div(class="mb-8 flex items-center justify-between")
    a(href="/dashboard" class="flex items-center gap-3 text-white")
      span(class="flex h-11 w-11 items-center justify-center rounded-lg bg-turquoise_surf-500 text-base font-bold text-deep_twilight-500") GD
      span
        span(class="block text-base font-semibold leading-tight") Gestor
        span(class="block text-xs text-frosted_blue-700") Documental
    button#sidebarClose(type="button" class="rounded-md p-2 text-frosted_blue-800 hover:bg-white/10 hover:text-white lg:hidden" aria-label="Cerrar menu")
      span(class="block h-0.5 w-5 rotate-45 bg-current")
      span(class="-mt-0.5 block h-0.5 w-5 -rotate-45 bg-current")

  nav(class="space-y-1")
    +navLink("/dashboard", "Dashboard", "DB")
    +navLink("/documents", "Documentos", "DO")
    if currentUser && currentUser.role === "admin"
      +navLink("/documents/create", "Cargar documento", "UP", true)
    +navLink("/approvals", "Aprobar", "AP")
    if currentUser && currentUser.role === "admin"
      div(class="px-3 pb-1 pt-5 text-xs font-semibold uppercase tracking-wide text-frosted_blue-700") Administracion
      +navLink("/categories", "Categorias", "CA")
      +navLink("/users", "Usuarios", "US")

  div(class="mt-auto rounded-lg border border-white/10 bg-white/5 p-4 text-sm text-frosted_blue-800")
    p(class="font-semibold text-white") Sesion activa
    if currentUser
      p(class="mt-1 truncate")= currentUser.email
      p(class="mt-2 inline-flex rounded-full bg-turquoise_surf-500 px-2 py-1 text-xs font-semibold text-deep_twilight-500")= currentUser.role
    else
      p(class="mt-1") Invitado
